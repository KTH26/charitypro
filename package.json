{
  "name": "charity-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.cjs\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "server": "node server.cjs",
    "test": "vitest run",
    "test:atomicity": "tsx scripts/test-atomicity.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@hebcal/core": "^6.6.0",
    "hono": "^4.12.27",
    "idb-keyval": "^6.2.5",
    "jose": "^5.9.6",
    "lucide-react": "^1.21.0",
    "number-to-words": "^1.2.4",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-plaid-link": "^4.1.1",
    "react-router-dom": "^7.18.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.13.2",
    "@types/number-to-words": "^1.2.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^24.1.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.7.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^1.6.0",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "lz-string": "file:./mock-lz-string"
  }
}
